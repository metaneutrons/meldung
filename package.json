    "next": "16.2.9",
    "next-auth": "^5.0.0-beta.31",
    "next-intl": "4.13.1",
    "nodemailer": "^9.0.3",
    "postgres": "^3.4.9",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-markdown": "^10.1.0",
    "tailwind-merge": "^3.6.0",
    "yaml": "2.9.0",
    "zod": "3.25.7",
    "zustand": "5.0.14"

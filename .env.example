# =============================================================================
# Meldung — Environment variables
# =============================================================================
# All values here OVERRIDE meldung.config.yaml, so secrets never need to live
# in the (version-controlled) YAML. Set these in your host / Vercel project.
# =============================================================================

# --- Authentication (optional SSO) ---
AUTH_ENABLED=false
AUTH_SECRET=generate-a-random-secret-here
# AUTH_ISSUER=https://idp.example.com/realms/main
# AUTH_CLIENT_ID=meldung
# AUTH_CLIENT_SECRET=your-client-secret

# --- E-mail delivery (SMTP) ---
# EMAIL_ENABLED=true
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=true
# SMTP_USER=noreply@example.com
# SMTP_PASS=your-smtp-password
# SMTP_FROM=IT-Security <it-security@example.com>
# SMTP_RECIPIENTS=cert@example.com,dpo@example.com

# --- Znuny / OTRS delivery ---
# ZNUNY_ENABLED=true
# ZNUNY_BASE_URL=https://znuny.example.com/otrs/nph-genericinterface.pl/Webservice/...
# ZNUNY_USERNAME=api-user
# ZNUNY_PASSWORD=your-api-password

# --- OTOBO delivery (OTRS fork — same REST connector as Znuny) ---
# OTOBO_ENABLED=true
# OTOBO_BASE_URL=https://otobo.example.com/otobo/nph-genericinterface.pl/Webservice/...
# OTOBO_USERNAME=api-user
# OTOBO_PASSWORD=your-api-password

# --- Generic webhook (POSTs the JSON payload to any URL: SOAR, n8n, SIEM, ...) ---
# WEBHOOK_ENABLED=true
# WEBHOOK_URL=https://hooks.example.com/incident
# WEBHOOK_SECRET=generate-a-random-secret-here   # enables HMAC-SHA256 body signature

# --- Zammad delivery (helpdesk REST API, token auth) ---
# ZAMMAD_ENABLED=true
# ZAMMAD_BASE_URL=https://zammad.example.com
# ZAMMAD_TOKEN=your-api-token

# --- Persistence (optional audit trail) ---
# PERSISTENCE_ENABLED=true
# PERSISTENCE_DRIVER=postgres        # "file" (self-hosted) or "postgres" (serverless)
# DATABASE_URL=postgres://user:pass@host:5432/db

# --- Bot protection (invisible proof-of-work captcha) ---
# Secret that signs the captcha challenges. Falls back to AUTH_SECRET.
# Required across instances on serverless so challenges verify consistently.
# CAPTCHA_SECRET=generate-a-random-secret-here
